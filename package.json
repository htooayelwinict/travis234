{
  "name": "allthebest-appv23",
  "version": "2.3.0",
  "description": "Global launcher and installer wrapper for the appv23 Docker sandbox.",
  "private": true,
  "license": "UNLICENSED",
  "bin": {
    "appv23-sandbox": "bin/appv23-sandbox.js"
  },
  "files": [
    "bin/appv23-sandbox.js",
    "README.md",
    "package.json"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "install:appv23": "bash scripts/install-appv23-sandbox.sh",
    "image:appv23:release": "docker build --pull=false -f Dockerfile.appv23.release -t ghcr.io/htooayelwinict/appv23:production .",
    "qa:installer": "node --test tests/appv23-sandbox-global.test.js && bash -n scripts/install-appv23-sandbox.sh && npm pack --dry-run",
    "test:global-sandbox": "node --test tests/appv23-sandbox-global.test.js",
    "tui": "npm --prefix appV2.3 run tui --",
    "tui:v22": "npm --prefix appV2.2 run tui --",
    "tui:v23": "npm --prefix appV2.3 run tui --",
    "tui:v23:sandbox": "npm --prefix appV2.3 run tui:sandbox --"
  }
}
